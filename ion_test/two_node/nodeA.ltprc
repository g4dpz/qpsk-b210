## LTP configuration for Node A
## Engine ID: 1
## Remote engine: 2 (Node B)

1 32

## span to engine 2 (Node B):
##   engine_id=2, max_export_sessions=32, max_import_sessions=32,
##   max_segment_size=1400, aggregation_size_threshold=1400,
##   aggregation_time_limit=1, LSO command
a span 2 32 32 1400 1400 1 'udplso 127.0.0.1:1113'

## Start with LSI command (receive UDP datagrams from modem on :1114)
s 'udplsi 127.0.0.1:1114'
