## LTP configuration for Node B
## Engine ID: 2
## Remote engine: 1 (Node A)

1 32

## span to engine 1 (Node A):
##   engine_id=1, max_export_sessions=32, max_import_sessions=32,
##   max_segment_size=1400, aggregation_size_threshold=1400,
##   aggregation_time_limit=1, LSO command
a span 1 32 32 1400 1400 1 'udplso 127.0.0.1:1113'

## Start with LSI command (receive UDP datagrams from modem on :1114)
s 'udplsi 127.0.0.1:1114'
