## BP configuration for node 2 (receiver)
## Receives bundles via STCP from ltp_cla_app egress at 127.0.0.1:4557

1

a scheme ipn 'ipnfw' 'ipnadminep'

a endpoint ipn:2.0 x
a endpoint ipn:2.1 x
a endpoint ipn:2.2 x

a protocol stcp 1400 100

## Induct - listens for bundles from ltp_cla_app egress
a induct stcp 127.0.0.1:4557 stcpcli

## Outduct - for return traffic (not used in this test)
a outduct stcp 127.0.0.1:4570 stcpclo

s
